       <widget class="QDateEdit" name="Vdateventetxt">
        <property name="geometry">
         <rect>
          <x>160</x>
          <y>70</y>
          <width>171</width>
          <height>51</height>
         </rect>
        </property>
        <property name="styleSheet">
         <string notr="true">QDateEdit {
    background-color: #F5C23C;
    color: black;
    border-radius: 20px;
    padding: 5px 20px;
    font-weight: bold;
    border: 2px solid #D4AC0D;
}

QDateEdit:hover {
    background-color: #2E1A62;
    color: white;
    border: 2px solid #F5C23C;
}

QDateEdit::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 25px;
    border-left: 1px solid #D4AC0D;
}

QDateEdit::down-arrow {
    width: 10px;
    height: 10px;
}

/* Style pour le calendrier */
QCalendarWidget {
    background-color: white;
    color: black;
    border: 2px solid #2E1A62;
    border-radius: 10px;
    font-size: 12px;
}

/* En-tête du calendrier (mois/année) */
QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #2E1A62;
    color: white;
    font-weight: bold;
    min-height: 30px;
}

/* Boutons de navigation */
QCalendarWidget QToolButton {
    background-color: #2E1A62;
    color: white;
    font-weight: bold;
    icon-size: 16px;
}

QCalendarWidget QToolButton:hover {
    background-color: #F5C23C;
    color: black;
}

/* Mois et année dans l'en-tête */
QCalendarWidget QMenu {
    background-color: white;
    color: black;
    font-weight: normal;
}

/* Jours de la semaine */
QCalendarWidget QWidget#qt_calendar_calendarview {
    background-color: white;
    alternate-background-color: #f0f0f0;
}

QCalendarWidget QAbstractItemView:enabled {
    color: black;
    background-color: white;
    selection-background-color: #2E1A62;
    selection-color: white;
    font-weight: normal;
}

/* Cellules des jours */
QCalendarWidget QAbstractItemView:enabled:selected {
    background-color: #2E1A62;
    color: white;
    font-weight: bold;
}

QCalendarWidget QAbstractItemView:enabled:hover {
    background-color: #F5C23C;
    color: black;
}

/* Jours d'autres mois */
QCalendarWidget QAbstractItemView:enabled:!selected:!active {
    color: #666666;
}

/* Jour actuel */
QCalendarWidget QAbstractItemView:enabled:selected:focus {
    background-color: #F5C23C;
    color: black;
    border: 2px solid #2E1A62;
}</string>
        </property>
        <property name="calendarPopup">
         <bool>true</bool>
        </property>
