     <widget class="QTableWidget" name="tableLignesVente">
      <property name="geometry">
       <rect>
        <x>650</x>
        <y>20</y>
        <width>751</width>
        <height>491</height>
       </rect>
      </property>
      <property name="styleSheet">
       <string notr="true">QTableView {
    background-color: #FFFFFF;
    alternate-background-color: #F7F9FC;
    color: #2D3748;
    gridline-color: #E2E8F0;
    selection-background-color: #3182CE;
    selection-color: white;
    border: 1px solid #CBD5E0;
    font-size: 11px;           /* réduit de 13 → 11 */
    font-family: &quot;Segoe UI&quot;,Arial,sans-serif;
    outline: none;
}

QTableView::item {
    padding: 5px 8px;          /* était 8px 12px → plus compact */
    border-bottom: 1px solid #EDF2F7;
}

QTableView::item:selected {
    background-color: #3182CE;
    color: white;
    font-weight: bold;
}

QTableView::item:hover {
    background-color: #EBF4FF;
}

QHeaderView::section {
    background-color: #F5C23C;   /* ton jaune signature */
    color: white;
    padding: 8px 6px;           /* réduit de 12px → 8px */
    border: none;
    font-weight: bold;
    font-size: 11px;            /* réduit */
    text-align: center;
}

/* Coins arrondis uniquement si tu veux garder l'effet (sinon tu peux supprimer) */
QHeaderView::section:first { border-top-left-radius: 6px; }
QHeaderView::section:last  { border-top-right-radius: 6px; }

/* Barre de défilement fine et discrète */
QScrollBar:vertical {
    border: none;
    background: #F1F5F9;
    width: 9px;                 /* plus fine : 12 → 9px */
    margin: 0;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    background: #A0AEC0;
    border-radius: 4px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #718096;
}</string>
