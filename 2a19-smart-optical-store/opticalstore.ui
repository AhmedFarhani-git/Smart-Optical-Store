       <property name="styleSheet">
        <string notr="true">QComboBox {
    background-color: #F5C23C;
    color: black;
    border-radius: 20px;
    padding: 5px 20px;
    font-weight: bold;
}

QComboBox:hover {
background-color: rgb(46, 26, 98);
    color: white;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border-left: none;
    background-color: transparent;
}

QComboBox::down-arrow {
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: #F5C23C;       /* list background */
    color: black;                     /* text color */
    selection-background-color: #000080; /* selected item background */
    selection-color: white;           /* selected item text */
    border-radius: 10px;
    padding: 5px;
}
</string>
