      <widget class="QComboBox" name="VtriComboBox">
       <property name="geometry">
        <rect>
         <x>831</x>
         <y>10</y>
         <width>161</width>
         <height>41</height>
        </rect>
       </property>
       <property name="styleSheet">
        <string notr="true">QComboBox {
    background-color: #F5C23C;
    color: black;
    border-radius: 20px;
    padding: 5px 20px;
    font-weight: bold;
    border: 2px solid #4b2e83;  /* Ajout d'une bordure pour mieux voir */
}

QComboBox:hover {
    background-color: rgb(46, 26, 98);
    color: white;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border-left: 2px solid #4b2e83;  /* Bordure à gauche de la flèche */
    border-radius: 0 15px 15px 0;     /* Coins arrondis à droite seulement */
}

QComboBox::down-arrow {
    width: 12px;
    height: 12px;
    image: url(:/icons/down_arrow.png);  /* Optionnel: image personnalisée */
}

QComboBox QAbstractItemView {
    background-color: #F5C23C;       /* Fond de la liste */
    color: black;                     /* Couleur du texte */
    selection-background-color: #000080; /* Fond de l'item sélectionné */
    selection-color: white;           /* Texte de l'item sélectionné */
    border-radius: 10px;
    padding: 5px;
    border: 2px solid #4b2e83;       /* Bordure pour la liste déroulante */
    outline: 0;                      /* Enlève le contour de focus */
}

QComboBox QAbstractItemView::item {
    padding: 8px 15px;               /* Espacement dans les items */
    border-radius: 5px;              /* Coins arrondis pour chaque item */
    margin: 2px;                     /* Espace entre les items */
}

QComboBox QAbstractItemView::item:hover {
    background-color: rgb(46, 26, 98);  /* Couleur au survol */
    color: white;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #000080;       /* Couleur quand sélectionné */
    color: white;
}

/* Style pour l'état pressé (quand on clique) */
QComboBox:pressed {
    background-color: #4b2e83;
    color: white;
}

/* Style pour l'état désactivé */
QComboBox:disabled {
    background-color: #cccccc;
    color: #666666;
}

/* Style pour l'état focus (quand il a le focus clavier) */
QComboBox:focus {
    border: 3px solid #4b2e83;
    background-color: #F5C23C;
    color: black;
}</string>
